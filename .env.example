# ============================================================
# hozt-astro Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# --- Required ---

# Full public URL of this site (no trailing slash).
# Used for canonical links, OG URLs, sitemap, and robots.txt.
SITE_URL=https://example.com

# Base URL of your WordPress instance (no trailing slash).
# GraphQL endpoint will be: {API_URL}/graphql
API_URL=https://cms.example.com

# --- Content Routing ---

# Set to "articles" to use /articles/ routes instead of /blog/.
# Leave empty or set to "blog" for default /blog/ routes.
POST_ALIAS=blog

# Position of breadcrumbs in page banners: top | middle | bottom
BREADCRUMB_POSITION=middle

# --- Forms & CAPTCHA ---

# Cloudflare Turnstile site key (public, safe to expose in browser).
# Get from: https://dash.cloudflare.com/ → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key (server-side only, never expose publicly).
TURNSTILE_SECRET_KEY=

# --- Email Delivery (Mailjet) ---

# Mailjet API credentials for sending contact form emails.
# Get from: https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=
MAILJET_API_SECRET=

# Email address that receives contact form submissions.
MAILJET_TO_EMAIL=hello@example.com

# --- Admin & Editor ---

# Secret key for enabling admin edit mode.
# When set, visiting /?editor={EDITOR_KEY} stores a cookie that shows
# edit links pointing to the WordPress dashboard.
EDITOR_KEY=

# --- Analytics ---

# Google Analytics / Tag Manager measurement ID (e.g. G-XXXXXXXXXX or GTM-XXXXXXX).
GA_ID=

# Google Ads conversion ID for contact form submission tracking (optional).
PUBLIC_GA_AD_CONVERSION_ID=

# --- Site Metadata ---

# Fallback site title used in <title> tags when no page-specific title is found.
SITE_TITLE=My Site

# Timezone for date formatting (IANA timezone name, e.g. America/Chicago).
# Defaults to UTC if not set.
TIME_ZONE=UTC
