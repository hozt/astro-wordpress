---
import Layout from "../layouts/Layout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { GET_PODCAST_EPISODES, GET_PODCAST_COUNT, GET_TEMPLATE } from "../lib/queries";
import Pagination from "../components/Pagination.astro";
import PodcastPreview from "../components/partials/PodcastPreview.astro";
import client from "../lib/apolloClient";
import { getTotalCount } from "../lib/fetchAllResults";
import { isEnabled } from '../lib/enabledFeatures';

if (!isEnabled('podcasts')) {
  return Astro.redirect('/404');
}

const ITEMS_PER_PAGE = 10;

const currentPage = 1;
let totalPages, title, podcasts, crumbs, template;
try
{
  const { data: templateData } = await client.query({
    query: GET_TEMPLATE,
    variables: { slug: 'podcast' },
  });

  template = templateData.templateBy;
  title = template?.title || 'Podcast Episodes';

  const totalArticles = await getTotalCount(GET_PODCAST_COUNT);

  const { data: podcastData } = await client.query({
    query: GET_PODCAST_EPISODES,
    variables: {
      first: 10,
      after: null,
    },
  });

  podcasts = podcastData?.allNodes?.nodes;
  totalPages = Math.ceil(totalArticles / ITEMS_PER_PAGE);
  crumbs = [{'label': title}];

  if (!podcasts || podcasts.length === 0) {
    return Astro.redirect('/404');
  }
} catch (error) {
  console.error('Podcasts are disabled');
  return Astro.redirect('/404');
}

let PodcastSubscribe = null;
let podcastSubscribeExists = false;

let components = import.meta.glob('../componentsSite/PodcastSubscribe.astro');

if (components['../componentsSite/PodcastSubscribe.astro']) {
  try {
    PodcastSubscribe = (await components['../componentsSite/PodcastSubscribe.astro']() as { default: any }).default;
    podcastSubscribeExists = true;
  } catch (error) {}
}

---

<Layout title={`${title} - Page ${currentPage}`} description={template?.metaDescription} templateId={template?.databaseId} classes="podcasts">
  <BannerTitle
    title={title}
    subtitle={template?.subtitle}
    image={template?.bannerImage?.sourceUrl}
    width={template?.bannerImage?.mediaDetails.width}
    height={template?.bannerImage?.mediaDetails.height}
    crumbs={crumbs}
  />
  <div class="main-body">

    <div class="podcast-subscribe">
      <div>Subscribe on:</div>
      {podcastSubscribeExists && <PodcastSubscribe />}
    </div>
    {podcasts.map((podcast) => (
      <PodcastPreview podcast={podcast} />
    ))}
    <Pagination currentPage={currentPage} totalPages={totalPages} />
  </div>
</Layout>
