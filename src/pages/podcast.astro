---
import Layout from "../layouts/Layout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { GET_PODCAST_EPISODES, GET_PODCAST_COUNT, GET_TEMPLATE } from "../lib/queries";
import Pagination from "../components/Pagination.astro";
import PodcastPreview from "../components/partials/PodcastPreview.astro";
import client from "../lib/apolloClient";
import { getTotalCount } from "../lib/fetchAllResults";

const ITEMS_PER_PAGE = 10;

const currentPage = 1;

const { data: templateData } = await client.query({
  query: GET_TEMPLATE,
  variables: { slug: 'podcast' },
});

const template = templateData.templateBy;
const title = template?.title || 'Podcast Episodes';

const totalArticles = await getTotalCount(GET_PODCAST_COUNT);

const { data: podcastData } = await client.query({
  query: GET_PODCAST_EPISODES,
  variables: {
    first: 10,
    after: null,
  },
});

const podcasts = podcastData?.allNodes?.nodes;
const totalPages = Math.ceil(totalArticles / ITEMS_PER_PAGE);
const crumbs = [{'label': title}];

if (!podcasts || podcasts.length === 0) {
  return Astro.redirect('/404', '404');
}

---

<Layout title={`${title} - Page ${currentPage}`} description={template?.metaDescription} templateId={template?.databaseId} classes="posts">
  <BannerTitle
    title={title}
    subtitle={template?.subtitle}
    image={template?.bannerImage?.sourceUrl}
    width={template?.bannerImage?.mediaDetails.width}
    height={template?.bannerImage?.mediaDetails.height}
    crumbs={crumbs}
  />
  <div class="main-body">
    {podcasts.map((podcast) => (
      <PodcastPreview podcast={podcast} />
    ))}
    <Pagination currentPage={currentPage} totalPages={totalPages} />
  </div>
</Layout>
