---
// src/pages/catalog/cart.astro
import Layout from '../../layouts/Layout.astro';
import { cartItems } from '../../store/cartStore';

const shippingMethods = [
  { id: 'standard', name: 'Standard Shipping', price: 5 },
  { id: 'express', name: 'Express Shipping', price: 15 },
];

const items = cartItems.get();
---

<Layout title="Your Cart">
  <div class="container p-6 mx-auto">
    <h1 class="mb-4 text-3xl font-bold">Your Cart</h1>
    <div id="cart-items" class="mb-4">
      {items.map(item => (
        <div class="flex justify-between py-2 border-b border-gray-200">
          <span>{item.name} - ${item.price.toFixed(2)}</span>
          <div>
            <div class="flex items-center border border-gray-300 rounded-md">
              <button class="px-3 py-1 text-gray-600 bg-gray-100 hover:bg-gray-200" data-action="decrement" data-id={item.id}>-</button>
              <input type="number" class="w-12 text-center border-none" value={item.quantity} min="1" max="99" data-id={item.id}>
              <button class="px-3 py-1 text-gray-600 bg-gray-100 hover:bg-gray-200" data-action="increment" data-id={item.id}>+</button>
            </div>
            <button class="ml-2 text-red-500 hover:text-red-700" data-remove={item.id}>Remove</button>
          </div>
        </div>
      ))}
    </div>

    <h2 class="mb-4 text-xl font-semibold">Shipping Method</h2>
    <select id="shipping-method" class="p-2 mb-4 border border-gray-300 rounded-md">
      {shippingMethods.map(method => (
        <option value={method.id}>{method.name} - ${method.price.toFixed(2)}</option>
      ))}
    </select>

    <div class="flex justify-between mb-4 text-lg font-semibold">
      <span>Subtotal:</span>
      <span id="subtotal">$0.00</span>
    </div>
    <div class="flex justify-between mb-4 text-lg font-semibold">
      <span>Shipping:</span>
      <span id="shipping">$0.00</span>
    </div>
    <div class="flex justify-between text-lg font-semibold">
      <span>Total:</span>
      <span id="total">$0.00</span>
    </div>

    <button class="w-full px-4 py-2 mt-4 text-white transition-colors bg-blue-500 rounded-md hover:bg-blue-600">
      Proceed to Checkout
    </button>
  </div>
</Layout>

<script>
  import { cartItems, updateQuantity, removeFromCart, getCartTotal } from '../../store/cartStore';

  const shippingMethods = [
    { id: 'standard', name: 'Standard Shipping', price: 5 },
    { id: 'express', name: 'Express Shipping', price: 15 },
  ];

  function renderCart() {
    const cartItemsContainer = document.getElementById('cart-items');
    const items = cartItems.get();
    console.log('Rendering cart with items:', items);

    cartItemsContainer.innerHTML = items.map(item => `
      <div class="flex justify-between py-2 border-b border-gray-200">
        <span>${item.name} - $${item.price.toFixed(2)}</span>
        <div>
          <div class="flex items-center border border-gray-300 rounded-md">
            <button class="px-3 py-1 text-gray-600 bg-gray-100 hover:bg-gray-200 ${item.quantity <= 1 ? 'opacity-50 cursor-not-allowed' : ''}"
                    data-action="decrement"
                    data-id="${item.id}"
                    ${item.quantity <= 1 ? 'disabled' : ''}>-</button>
            <input type="number" class="w-12 text-center border-none" value="${item.quantity}" min="1" max="99" data-id="${item.id}">
            <button class="px-3 py-1 text-gray-600 bg-gray-100 hover:bg-gray-200" data-action="increment" data-id="${item.id}">+</button>
          </div>
          <button class="ml-2 text-red-500 hover:text-red-700" data-remove="${item.id}">Remove</button>
        </div>
      </div>
    `).join('');

    updateTotals();
  }

  function updateTotals() {
    const items = cartItems.get();
    const shippingMethodSelect = document.getElementById('shipping-method');
    const shippingMethod = shippingMethods.find(method => method.id === shippingMethodSelect.value);
    const { subtotal, shipping, total } = getCartTotal(items, shippingMethod);

    document.getElementById('subtotal').textContent = `$${subtotal.toFixed(2)}`;
    document.getElementById('shipping').textContent = `$${shipping.toFixed(2)}`;
    document.getElementById('total').textContent = `$${total.toFixed(2)}`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const cartItemsContainer = document.getElementById('cart-items');
    cartItemsContainer.addEventListener('click', (e) => {
      const target = e.target;
      console.log('Clicked element:', target);

      if (target.tagName === 'BUTTON') {
        if (target.dataset.action === 'increment' || target.dataset.action === 'decrement') {
          const id = parseInt(target.dataset.id); // Ensure id is a number
          const inputElement = target.parentElement.querySelector('input');
          const currentQuantity = parseInt(inputElement.value);
          const newQuantity = target.dataset.action === 'increment' ? currentQuantity + 1 : currentQuantity - 1;

          console.log('Action:', target.dataset.action, 'Current Quantity:', currentQuantity, 'New Quantity:', newQuantity);

          if (newQuantity >= 1 && newQuantity <= 99) {
            updateQuantity(id, newQuantity);
          }
        } else if (target.dataset.remove) {
          removeFromCart(parseInt(target.dataset.remove)); // Ensure id is a number
        }
      }
    });

    window.addEventListener('cartUpdated', (event) => {
      console.log('Cart updated event received:', event.detail);
      renderCart();
    });

    // cartItemsContainer.addEventListener('change', (e) => {
    //   if (e.target.type === 'number') {
    //     const id = e.target.dataset.id;
    //     const newQuantity = parseInt(e.target.value);
    //     if (newQuantity >= 1 && newQuantity <= 99) {
    //       updateQuantity(id, newQuantity);
    //       renderCart();
    //     }
    //   }
    // });

    const shippingMethodSelect = document.getElementById('shipping-method');
    shippingMethodSelect.addEventListener('change', updateTotals);

    // Initial render
    renderCart();
  });
</script>