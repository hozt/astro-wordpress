---
/**
 * @file eDiTor/[slug].astro
 * @description Admin editor route for previewing pages with edit access.
 */
import client from "../../lib/apolloClient";
import { GET_EDITOR_KEY } from "../../lib/queries";

export async function getStaticPaths() {
  const { data } = await client.query({
    query: GET_EDITOR_KEY,
  });

  const editorKey = data.customSiteSettings.editorKey;

  return [
    { params: { slug: editorKey } }
  ];
}

const { slug } = Astro.params;

const { data } = await client.query({
  query: GET_EDITOR_KEY,
});

const editorKey = data?.customSiteSettings?.editorKey;

if (editorKey !== slug) {
  return Astro.redirect('/404');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Authenticating...</title>
</head>
<body>
  <p>Authenticating...</p>

  <script define:vars={{ editorKey }}>
  // Temporary: Client-side cookie for dev
  function setCookie(name, value, days) {
    const date = new Date();
    date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
    const expires = "expires=" + date.toUTCString();
    document.cookie = name + "=" + value + ";" + expires + ";path=/;SameSite=Strict;Secure";
  }

  if (editorKey) {
    setCookie('adminAuth', editorKey, 7);
    console.log('Auth cookie set');
    window.location.href = '/';
  }
</script>

</body>
</html>
