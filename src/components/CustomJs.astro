---
/**
 * @file CustomJs.astro
 * @description Injects per-page custom JavaScript strings passed from the CMS.
 */
const { customJs } = Astro.props;

if (!customJs) {
  return '';
}

---

{customJs && (
<script define:vars={{ customJs }}>
    (function() {
    const decodedJs = customJs.replace(/&gt;/g, '>').replace(/&lt;/g, '<').replace(/&amp;/g, '&');
    try {
        eval(decodedJs);
    } catch (error) {
        console.error('Error in custom JS:', error);
    }
    })();
</script>
)}