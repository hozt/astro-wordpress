---
/**
 * @file MenuToggle.astro
 * @description Hamburger button that toggles the mobile navigation menu open/closed.
 */
---
<div class="md:hidden mobile-toggle">
    <button
        id="menu-toggle"
        aria-label="Toggle Menu">
        <i id="menu-icon" class="icon-[mdi--menu]"></i>
    </button>
</div>
