---
/**
 * @file Analytics.astro
 * @description Injects Google Tag Manager / gtag.js script for analytics tracking.
 */
const gaId = import.meta.env.GA_ID;
const gaAdConversionId = import.meta.env.PUBLIC_GA_AD_CONVERSION_ID;

if (!gaId) {
  return null;
}

const analyticsScript = `
function loadScript(src) {
  return new Promise((resolve, reject) => {
    const script = document.createElement('script');
    script.async = true;
    script.src = src;
    script.onload = resolve;
    script.onerror = reject;
    document.body.appendChild(script);
  });
}

window.addEventListener('load', async function() {
  try {
    await loadScript('https://www.googletagmanager.com/gtag/js?id=${gaId}');
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '${gaId}');
    ${gaAdConversionId ? `gtag('config', '${gaAdConversionId}');` : ''}
  } catch (error) {
    console.error("Failed to load analytics: ", error);
  }
});
`;
---

<script is:inline set:html={analyticsScript}></script>
