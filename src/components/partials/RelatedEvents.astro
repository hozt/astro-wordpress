---
const { relatedEvents, relatedEventTitle, excerpt } = Astro.props;

const hasRelatedPosts = relatedEvents && Array.isArray(relatedEvents) && relatedEvents.length > 0;
const title = relatedEventTitle || 'Related Events';

// remove any that do not have a title or slug
const filteredRelatedEvents = relatedEvents.filter(post => post?.title && post?.slug);
if (!hasRelatedPosts || filteredRelatedEvents.length === 0) {
  return '';
}

---

<div class="related-events">
  <div class="heading">{title}</div>
  <ul class="list">
    {filteredRelatedEvents.map((related) => (
      <li>
        <a href={`/event/${related.slug}/`} class="title">
          {related.title}
        </a>
        {excerpt && <div class="excerpt" set:html={related.excerpt} />}
      </li>
    ))}
  </ul>
</div>
