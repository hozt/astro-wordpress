---
import { stripTags } from '../..//lib/utils.js';
import { formatDateShort, formatTime } from '../../lib/formatDate.js';
const { relatedEvents, relatedEventTitle, excerpt, content } = Astro.props;
const hasRelatedPosts = relatedEvents && Array.isArray(relatedEvents) && relatedEvents.length > 0;
const title = relatedEventTitle || 'Related Events';

// remove any that do not have a title or slug
const filteredRelatedEvents = relatedEvents.filter(post => post?.title && post?.slug);
if (!hasRelatedPosts || filteredRelatedEvents.length === 0) {
  return '';
}

---

<div class="related-events">
  <h3 class="heading">{title}</h3>
  <ul class="list">
    {filteredRelatedEvents.map((related) => (
      <li>
        <div class="event-start">
          {formatDateShort(related.startDatetime)} <span class="time">{formatTime(related.startDatetime)}</span>
          {related.endDatetime  && (<span> - {formatTime(related.endDatetime)}</span>)}
        </div>
        <div class="title-location">
          <a href={`/event/${related.slug}/`} class="title">{related.title}</a>
          {related.location && <span class="location"> - {related.location}</span>}
        </div>
        { excerpt && <div class="excerpt" set:html={related.excerpt} /> }
        { content && <div class="content" set:html={stripTags(related.content)} /> }
      </li>
    ))}
  </ul>
</div>
